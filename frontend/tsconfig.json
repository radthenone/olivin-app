{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "moduleResolution": "bundler",
    "moduleSuffixes": [".native", ".web", ""],
    "baseUrl": ".",
    "paths": {
      "@app": [
        "./app"
      ],
      "@app/*": [
        "./app/*"
      ],
      "@assets/": [
        "./assets"
      ],
      "@assets/*": [
        "./assets/*"
      ],
      "@lib": [
        "lib"
      ],
      "@lib/*": [
        "lib/*"
      ],
      "@styles": [
        "styles"
      ],
      "@styles/*": [
        "styles/*"
      ],
      "@core": [
        "./src/core/"
      ],
      "@core/*": [
        "./src/core/*"
      ],
      "@http": [
        "./src/core/api/"
      ],
      "@http/*": [
        "./src/core/api/*"
      ],
      "@features": [
        "./src/features/"
      ],
      "@features/*": [
        "./src/features/*"
      ],
      "@ui": [
        "./src/ui/"
      ],
      "@ui/*": [
        "./src/ui/*"
      ],
      "@api": [
        "./src/api/"
      ],
      "@api/*": [
        "./src/api/*"
       ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.web.ts",
    "**/*.web.tsx",
    "**/*.android.ts",
    "**/*.android.tsx",
    "**/*.ios.ts",
    "**/*.ios.tsx",
    "**/*.native.ts",
    "**/*.native.tsx",
    "nativewind-env.d.ts"
  ],
  "exclude": [
    "../packages/**/frontend/node_modules/**",
    "../packages/**/frontend/dist/**",
    "node_modules"
  ]
}
