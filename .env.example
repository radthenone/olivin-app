#PROJECT
BACKEND_URL=127.0.0.1:8000
FRONTEND_URL=127.0.0.1:8081
ANDROID_URL=10.0.2.2:8081
#POSTGRES
POSTGRES_DB=django_db
POSTGRES_USER=django_user
POSTGRES_PASSWORD=django_password
POSTGRES_HOST=db
POSTGRES_PORT=5432
#MINIO
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=admin
#DJANGO
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=random_key
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,10.0.2.2
